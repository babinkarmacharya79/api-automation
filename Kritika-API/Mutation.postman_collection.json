          "script": {
            "exec": [
              "pm.test(\"SignUp Validation\",()=>\r",
              "{\r",
              "   pm.response.to.have.status(200); \r",
              "})\r",
              "const JsonData=pm.response.json();\r",
              "pm.test(\"DataType Validation\",()=>\r",
              "{\r",
              "    pm.expect(JsonData.data.login.result).to.be.an(Array);\r",
              "    JsonData.data.login.result.forEach(row=>\r",
              "    {\r",
              "        pm.expect(row.id).to.be.an(String);\r",
              "        pm.expect(row.fullname).to.be.an(String);\r",
              "        pm.expect(row.isActive).to.be.an(Boolean);\r",
              "    })\r",
