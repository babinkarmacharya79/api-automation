                  "   pm.expect(jsonData.data.login.result.fullName).to.be.a(\"string\");\r",
                  "   pm.expect(jsonData.data.login.result.isActive).to.be.true;\r",
                  "   pm.expect(jsonData.data.login.result.portfoliosMetadata.portfolioRole).to.equal(\"GUEST\");\r",
